{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx nx lint inbox --quiet --fix 2>&1 | tail -20"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx nx run-many --target=test --all --reporter=dot 2>&1 | tail -30"
          }
        ]
      }
    ]
  }
}
